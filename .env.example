# Copy this file to .env and fill in values

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-prod

# Optional — defaults to SQLite. For Postgres use: postgresql://user:pass@host/dbname
# DATABASE_URL=sqlite:///site.db

# Set to "true" to enable Flask debug mode (never use in production)
FLASK_DEBUG=false
